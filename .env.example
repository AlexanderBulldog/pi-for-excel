# Minimum deploy config. Change ADDIN_BASE_URL later when the internal URL is approved.
ADDIN_BASE_URL=https://pi-excel.internal.test
ADDIN_SITE_ADDRESS=:8080

# Internal OpenAI-compatible LLM gateway.
OPENAI_BASE_URL=https://llm.company.local/v1
LLM_MODEL=company-model

# Optional. Do not put a real secret here if ordinary users must not see it:
# runtime-config.json is served to the Excel add-in.
OPENAI_API_KEY=

# Tell Pi the real model context size so compaction/tool output limits behave.
CORPORATE_GATEWAY_CONTEXT_WINDOW=65536
CORPORATE_GATEWAY_NAME=Company LLM

# Default: route browser LLM traffic through this Docker/Caddy origin.
# This avoids Office WebView CORS problems and keeps OPENAI_API_KEY out of
# /runtime-config.json.
CORPORATE_GATEWAY_PROXY=1

# Pilot-friendly for company/self-signed upstream certificates. Set to 0 when
# the container trusts the upstream CA normally.
CORPORATE_GATEWAY_TLS_INSECURE_SKIP_VERIFY=1

# Optional direct TLS. Prefer company-issued certs trusted by tester machines.
# CADDY_TLS_CERT_FILE=/certs/pi-excel.crt
# CADDY_TLS_KEY_FILE=/certs/pi-excel.key
# CADDY_TLS_INTERNAL=1
