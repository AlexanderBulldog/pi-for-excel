# Public HTTPS URL your reverse proxy (host Caddy) serves. Used in
# manifest.prod.xml and as the same-origin base for /llm-gateway in
# runtime-config.json. Must match the site host in deploy/Caddyfile.example.
ADDIN_BASE_URL=https://pi-excel.internal.test

# Company LLM (OpenAI-compatible). Only the URL is used here, to derive the
# /llm-gateway path (e.g. /v1) in runtime-config.json.
# The real API KEY is NOT set here — it goes in the host Caddyfile, server-side.
OPENAI_BASE_URL=https://llm.company.local/v1
LLM_MODEL=your-model-id

# Display name and real model context size (for compaction / tool output limits).
CORPORATE_GATEWAY_NAME=Company LLM
CORPORATE_GATEWAY_CONTEXT_WINDOW=65536
